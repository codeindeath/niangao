# ==========================================
# 年糕 App — 环境变量
# 复制此文件为 .env 并填入真实值
# ==========================================

# Server
PORT=8080

# PostgreSQL (火山引擎 RDS)
DATABASE_URL=postgresql://user:password@host:5432/niangao

# Redis (火山引擎 Redis)
REDIS_URL=localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string

# 微信开放平台 (个人开发者注册: open.weixin.qq.com)
WECHAT_APP_ID=wx_placeholder_app_id
WECHAT_APP_SECRET=placeholder_app_secret

# DeepSeek API (platform.deepseek.com)
DEEPSEEK_API_KEY=sk-placeholder
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# AI 服务地址
AI_SERVICE_URL=http://localhost:8000
